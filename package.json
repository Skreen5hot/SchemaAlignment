{
  "name": "schema-alignment-service",
  "version": "0.1.0",
  "description": "Schema Alignment Service — deterministic CISM-to-viz:DatasetSchema transformation",
  "type": "module",
  "main": "dist/kernel/index.js",
  "types": "dist/kernel/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/kernel/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "clean": "rimraf dist dist-tests",
    "build:demo": "esbuild site/demo.ts --bundle --format=esm --target=es2022 --platform=browser --outfile=site/dist/demo.js"
  },
  "keywords": [
    "schema-alignment",
    "cism",
    "bibss",
    "viz",
    "json-ld",
    "deterministic"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "esbuild": "^0.27.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
